---
// Primary button (design system) — etykieta + strzałka w kółku. Dwa warianty:
// - yellow = PRIMARY 1 (żółty, duży; spec 1:1 z Figmy node 1663-28849)
// - dark   = PRIMARY 2 (czarny; do osobnej modyfikacji)
interface Props {
  /** Etykieta przycisku */
  label: string
  /** Link (domyślnie /cennik) */
  href?: string
  /** Wariant: yellow (Primary 1) lub dark (Primary 2) */
  variant?: 'dark' | 'yellow'
  /** Dodatkowe klasy na <a> (np. mt-2) */
  class?: string
}

const { label, href = '/cennik', variant = 'dark', class: className } = Astro.props
---

{variant === 'yellow' ? (
  <a
    href={href}
    class:list={['inline-flex items-center gap-[52px] bg-brand-yellow hover:bg-brand-yellow-hover h-[85px] pl-5 pr-2.5 rounded-[50px] transition-colors', className]}
  >
    <span class="px-2.5 text-[19px] font-semibold leading-[1.1] tracking-[-0.19px] text-black whitespace-nowrap">{label}</span>
    <span class="inline-flex items-center justify-center size-[62px] rounded-full bg-white shrink-0">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14" />
        <path d="M13 5l7 7-7 7" />
      </svg>
    </span>
  </a>
) : (
  <a
    href={href}
    class:list={['inline-flex items-center gap-3 bg-black hover:bg-brand-navy text-white font-semibold text-base lg:text-body-lg px-7 py-3.5 rounded-full transition-colors', className]}
  >
    {label}
    <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-brand-yellow shrink-0">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </a>
)}

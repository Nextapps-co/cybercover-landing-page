<!-- Scroll animation: replaces WordPress/Paula animation system -->
<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('.item').forEach(el => el.classList.add('animated'));
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });

  const el = document.querySelector('.ochrona360');
  if (el) observer.observe(el);
</script>

<style is:global>
  /* ============================================================
     Ochrona 360 diagram — ported 1:1 from cc-ochrona360.css
     Only change: WP utility classes replaced with explicit props
     ============================================================ */

  @keyframes cc-spin {
    0%   { transform: translate(-50%, -50%) rotate(0deg); }
    100% { transform: translate(-50%, -50%) rotate(360deg); }
  }

  .ochrona360 {
    --padding: 60px 0;
    --circle-top: 190px;
    position: relative;
    padding: var(--padding);
    overflow: hidden;
  }

  /* Arrow circle */
  .ochrona360 .arrow-circle {
    position: absolute;
    left: 50%;
    top: 0;
    z-index: 2;
    width: min(380px, 100%);
    transform: translateX(-50%);
  }

  .ochrona360 .arrow-circle svg {
    position: absolute;
    left: 50%;
    top: var(--circle-top);
    z-index: 2;
    width: min(380px, 90%);
    height: auto;
    animation: cc-spin 6s infinite linear;
  }

  /* Central photo */
  .ochrona360 .main-picture {
    margin: 7% auto 0;
    max-width: min(330px, 80%);
    position: relative;
    z-index: 1;
  }

  .ochrona360 .main-picture img {
    display: block;
    margin: 0 auto;
    max-width: 100%;
    height: auto;
  }

  /* Background shapes — hidden on mobile */
  .ochrona360 .bg {
    display: none;
  }

  /* Service items */
  .ochrona360 .item {
    position: relative;
    z-index: 3;
    margin: 1em auto;
    padding: 15px;
    width: min(calc(100% - 20px), 400px);
    border-radius: 20px;
    color: #000;
    background-color: #feffe0;
    gap: 12px;
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
  }

  .ochrona360 .item .item-icon {
    width: 48px;
    height: auto;
    flex-shrink: 0;
  }

  .ochrona360 .item p {
    margin: 0;
    font-size: 16px;
    line-height: 25px;
    text-transform: uppercase;
    font-weight: 600;
  }

  @media (min-width: 400px) {
    .ochrona360 .main-picture {
      margin-top: 0;
    }
  }

  /* ============ DESKTOP (900px+) ============ */
  @media (min-width: 900px) {
    .ochrona360 {
      --padding: 130px 0 110px;
      --circle-top: 50%;
    }

    .ochrona360 .arrow-circle {
      top: var(--circle-top);
    }

    .ochrona360 .main-picture {
      max-width: none;
      margin: 0 auto;
    }

    /* Items: absolute, with transition animation */
    .ochrona360 .item {
      position: absolute;
      margin: 0;
      transition: transform 1s;
      max-width: 280px;
    }

    /* --- Pre-animation (starting) positions --- */
    .ochrona360 .item.item1 {
      top: 20px;
      left: 50%;
      transition-delay: 1s;
      transform: translate(-70%, 30px);
    }
    .ochrona360 .item.item2 {
      top: 50%;
      left: 50%;
      transition-delay: 2s;
      transform: translate(110px, -130%);
    }
    .ochrona360 .item.item3 {
      left: 50%;
      bottom: 0;
      transition-delay: 3s;
      transform: translate(95px, -70%);
    }
    .ochrona360 .item.item4 {
      right: 50%;
      bottom: 0;
      transition-delay: 4s;
      transform: translate(-35px, -20%);
    }
    .ochrona360 .item.item5 {
      top: 50%;
      right: 50%;
      transition-delay: 5s;
      transform: translate(-140px, -70%);
    }

    /* --- Animated (final) positions --- */
    .ochrona360 .item.animated.item1 { transform: translate(-50%, 0); }
    .ochrona360 .item.animated.item2 { transform: translate(150px, -100%); }
    .ochrona360 .item.animated.item3 { transform: translate(65px, -50%); }
    .ochrona360 .item.animated.item4 { transform: translate(-65px, -50%); }
    .ochrona360 .item.animated.item5 { transform: translate(-150px, -100%); }

    /* Background decorative shapes */
    .ochrona360 .bg {
      display: block;
      position: absolute;
      top: 50%;
      z-index: 0;
    }

    .ochrona360 .bg.bg-l {
      right: 50%;
      transform: translate(-210px, -50%);
      mask: linear-gradient(to right, #fff0 0%, #ffff 50px);
    }

    .ochrona360 .bg.bg-r {
      left: 50%;
      transform: translate(210px, -50%);
      mask: linear-gradient(to left, #fff0 0%, #ffff 50px);
    }
  }

  @media (min-width: 1280px) {
    .ochrona360 .item {
      width: 300px;
    }
  }
</style>

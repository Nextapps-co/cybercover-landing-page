---
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Section from '../components/Section.astro'
import SectionHeading from '../components/SectionHeading.astro'
import StepsGrid from '../components/StepsGrid.astro'
import ArrowButton from '../components/ArrowButton.astro'
import CtaReady from '../components/CtaReady.astro'
import konsultacjeHero from '../assets/img/Konsultacje-portal.jpg'
import teamMeetingImg from '../assets/img/team-meeting.jpg'

const wsparcie = [
  {
    icon: '/img/ico-czas.svg',
    title: 'Oszczędzisz czas na zagadnieniach spoza Twojej specjalności',
  },
  {
    icon: '/img/ico-ekspert.svg',
    title: 'Masz dostęp do ekspertów bez długoterminowych zobowiązań',
  },
  {
    icon: '/img/ico-bledy.svg',
    title: 'Unikniesz kosztownych błędów prawnych i technicznych',
  },
]

const problemy = [
  {
    title: 'Ochrona danych klientów i pracowników',
    items: [
      'Czy moja zgoda na przetwarzanie danych jest prawidłowo sformułowana?',
      'Jakie są moje obowiązki gdy klient chce usunąć dane?',
      'Jak długo prawnie mogę przechowywać dane pracowników?',
      'Kiedy muszę zgłaszać naruszenie danych do urzędu?',
      'Czy mogę legalnie przekazać dane klientów firmie zewnętrznej?',
      'Jakie dokumenty powinienem przygotować na kontrolę?',
    ],
  },
  {
    title: 'Zabezpieczenia danych organizacji',
    items: [
      'Jakie cechy mają bezpieczne hasła?',
      'Jak rozpoznać phishing w mailach?',
      'Jakie kryteria przy wyborze antywirusa dla organizacji?',
      'Jak często robić kopie zapasowe i gdzie je przechowywać?',
      'Jakie zasady bezpieczeństwa przy pracy zdalnej?',
      'Gdzie znaleźć sprawdzone narzędzia do szyfrowania?',
    ],
  },
  {
    title: 'Powrót do pracy po awarii',
    items: [
      'Jakie elementy musi zawierać plan awaryjny?',
      'Jak określić priorytetowe systemy w organizacji?',
      'Gdzie najlepiej przechowywać kopie zapasowe?',
      'Jak często testować procedury awaryjne?',
      'Jakie scenariusze awarii powinienem przewidzieć?',
      'Gdzie szukać pomocy w sytuacjach kryzysowych?',
    ],
  },
]

const persony = [
  {
    title: 'Właściciele organizacji',
    desc: 'gdy dostają pisma od kontroli, słyszą o atakach hackerskich w mediach lub uświadamiają sobie ryzyko przestoju organizacji.',
  },
  {
    title: 'Menedżerowie bez technicznego zaplecza',
    desc: 'gdy muszą podjąć decyzje o bezpieczeństwie, ale nie mają własnego działu IT.',
  },
  {
    title: 'Osoby odpowiedzialne za HR i administrację',
    desc: 'przy problemach z danymi pracowników, przygotowywaniu dokumentów na kontrole lub wdrażaniu procedur.',
  },
  {
    title: 'Koordynatorzy projektów i kierownicy działów',
    desc: 'gdy pracują z wrażliwymi danymi lub muszą przygotować swój zespół na różne scenariusze awaryjne.',
  },
  {
    title: 'Administratorzy IT',
    desc: 'którzy potrzebują porady przy wyborze rozwiązań lub planowaniu procedur bezpieczeństwa.',
  },
]

const kroki = [
  { n: '01', text: 'Zaloguj się do Portalu Klienta' },
  { n: '02', text: 'Wybierz dogodny termin w kalendarzu ekspertów' },
  {
    n: '03',
    text: 'Wyślemy przypomnienia mailem i SMS-em przed spotkaniem',
    note: 'Na konsultację możesz zaprosić osoby ze swojego zespołu — nie ma ograniczeń co do liczby uczestników z Twojej strony.',
    image: '/img/krok-3.png',
  },
]

const rezultaty = [
  {
    cardBg: 'bg-brand-blue-light',
    title: 'Co robimy w trakcie konsultacji',
    items: [
      'Wyjaśniamy konkretne zagadnienia i pojęcia',
      'Podajemy wytyczne jak postępować w danej sytuacji',
      'Proponujemy bardziej zaawansowane usługi jeśli potrzeba',
    ],
    tag: 'Działania',
    tagBg: 'bg-[#FFF5E0]',
  },
  {
    cardBg: 'bg-brand-blue-light',
    title: 'Czego nie robimy w trakcie rozmowy',
    items: [
      'Nie przeprowadzamy pełnego audytu Twojej sytuacji',
      'Nie piszemy procedur i dokumentacji',
      'Nie konfigurujemy systemów i oprogramowania',
    ],
    tag: 'Ograniczenia',
    tagBg: 'bg-brand-tag-yellow',
  },
  {
    cardBg: 'bg-brand-blue-light',
    title: 'Po rozmowie będziesz miał',
    items: [
      'Jasność co do swojej sytuacji i następnych kroków',
      'Konkretne wskazówki jak rozwiązać swój problem',
      'Listę narzędzi lub zasobów, które możesz wykorzystać',
    ],
    tag: 'Efekty',
    tagBg: 'bg-white',
  },
]

const faq = [
  {
    q: 'Dlaczego nie szukać samemu w internecie?',
    a: 'Konsultacja z ekspertem oszczędza czas i chroni przed kosztownymi błędami. Zamiast spędzać godziny na szukaniu ogólnych porad w internecie, otrzymujesz konkretne wskazówki dostosowane do Twojej organizacji. Jedna nieprawidłowa decyzja w kwestii RODO czy bezpieczeństwa może kosztować bardzo dużo — lepiej zapytać eksperta wcześniej niż płacić za konsekwencje później.',
  },
  {
    q: 'Jak mam się przygotować do rozmowy?',
    a: 'Przygotuj listę konkretnych pytań, które chcesz zadać. Jeśli masz dokumenty związane z problemem (np. pisma, procedury), dobrze jest je mieć pod ręką. Nie musisz być ekspertem — wystarczy że opiszesz swoją sytuację.',
  },
  {
    q: 'Kto może skorzystać z konsultacji?',
    a: 'Każda osoba z wykupioną Ochroną 360. Może to być właściciel organizacji, menedżer, administrator, księgowy — każdy kto ma pytania w zakresie cyberbezpieczeństwa i zgodności z przepisami.',
  },
  {
    q: 'Ile kosztuje konsultacja?',
    a: 'Konsultacja wchodzi w zakres Ochrony 360. Możesz korzystać z niej wg reguł Twojego pakietu np. raz w miesiącu.',
  },
  {
    q: 'Kto może uczestniczyć w rozmowie?',
    a: 'Ty i dowolna liczba osób z twojego zespołu. Możesz zaprosić kolegów, współpracowników lub inne osoby, które są zaangażowane w dany temat.',
  },
  {
    q: 'Czy mogę nagrywać rozmowę?',
    a: 'Tak, możesz nagrywać konsultację na własny użytek. Poinformuj o tym na początku rozmowy.',
  },
  {
    q: 'Co jeśli nie znam się na technicznych szczegółach?',
    a: 'To żaden problem! Nasze konsultacje są dostosowane do poziomu wiedzy klienta. Wszystko wyjaśniamy prostym językiem.',
  },
  {
    q: 'Czy mogę przełożyć umówione spotkanie?',
    a: 'Tak, możesz zmienić termin w Portalu Klienta.',
  },
  {
    q: 'A jeśli czas konsultacji to za mało?',
    a: 'Jeśli temat jest bardzo złożony, możesz umówić się na kolejną konsultację lub zaproponujemy ci bardziej zaawansowaną usługę.',
  },
]
---

<BaseLayout
  title="Konsultacje z ekspertami – CyberCover"
  description="Konkretne odpowiedzi na Twoje pytania o RODO, bezpieczeństwo i procedury. Konsultacje z ekspertami w ramach Ochrony 360."
>
  <Hero
    badge="Ochrona 360"
    title="Konsultacje z ekspertami"
    intro="Konkretne odpowiedzi na Twoje pytania o RODO, bezpieczeństwo i procedury."
    subtitle="Zapytaj ekspertów o wszystko co Cię niepokoi."
    introSize="xl"
    bg="white"
    image={konsultacjeHero}
    imageAlt="Konsultacje z ekspertami — ilustracja"
  >
    <ArrowButton slot="cta" label="Umów konsultację" class="mt-2" />
  </Hero>

  <!-- ======== SEKCJA: Wsparcie zewnętrznych ekspertów ======== -->
  <Section>
    <SectionHeading tag="Wsparcie" title="Wsparcie zewnętrznych ekspertów" tagColor="cream" />

    <ul class="grid grid-cols-1 md:grid-cols-3 gap-5 list-none p-0">
      {wsparcie.map((item) => (
        <li
          class="relative bg-white rounded-card overflow-hidden min-h-[270px] p-7 lg:p-8 flex flex-col gap-9"
          style="background-image:url('/img/tlo-box-szersze.svg'); background-repeat:no-repeat; background-position:top right; background-size:cover;"
        >
          <img src={item.icon} alt="" aria-hidden="true" class="w-10 h-12 lg:w-12 lg:h-14 -mt-7 lg:-mt-8" />
          <h3 class="text-[22px] font-semibold leading-snug text-black max-w-[87%]">
            {item.title}
          </h3>
        </li>
      ))}
    </ul>
  </Section>

  <!-- ======== SEKCJA: Przykłady problemów ======== -->
  <Section padding="tight">
    <SectionHeading tag="Problemy" title="Przykłady problemów, które rozwiązujemy" tagColor="yellow" />

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_49%] gap-8 lg:gap-10 items-stretch">
      <ul class="flex flex-col gap-5 list-none p-0">
        {problemy.map((p) => (
          <li class="bg-brand-bg border border-brand-border rounded-card p-7 lg:p-8 flex flex-col gap-3">
            <h3 class="text-xl lg:text-2xl font-semibold leading-snug text-black">
              {p.title}
            </h3>
            <ul class="list-disc ml-5 space-y-1.5 text-body lg:text-base leading-cozy text-brand-text marker:text-brand-text">
              {p.items.map((i) => <li>{i}</li>)}
            </ul>
          </li>
        ))}
      </ul>
      <div class="relative rounded-card overflow-hidden order-first lg:order-none min-h-[300px] lg:min-h-0">
        <Image
          src={teamMeetingImg}
          alt="Zespół podczas konsultacji"
          width={900}
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </Section>

  <!-- ======== SEKCJA: Kto najczęściej umawia się na konsultacje (full-bleed gray) ======== -->
  <Section bg="bg-brand-bg">
    <SectionHeading tag="Problemy" title="Kto najczęściej umawia się z nami na konsultacje?" tagColor="yellow" />

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-10 list-none p-0">
      {persony.map((p) => (
        <li class="flex flex-col gap-4">
          <span class="inline-flex items-center justify-center w-[37px] h-[37px] rounded-full bg-brand-tag-blue">
            <img src="/img/mini-sygnet.svg" alt="" aria-hidden="true" class="w-[15px] h-auto" />
          </span>
          <h3 class="text-[19px] font-semibold leading-snug text-black">
            {p.title}
          </h3>
          <p class="text-base leading-cozy text-brand-text">
            {p.desc}
          </p>
        </li>
      ))}
    </ul>
  </Section>

  <!-- ======== SEKCJA: Kto odpowiada na Twoje pytania ======== -->
  <Section padding="tight" class="relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
      <div class="relative">
        <p class="font-medium uppercase text-sm tracking-wide mb-4">
          <span class="inline-flex items-center gap-2 bg-brand-tag-yellow border border-brand-tag-yellow px-4 py-1.5 rounded-full">
            <img src="/img/mini-sygnet.svg" alt="" aria-hidden="true" class="w-[19px] h-auto" />
            specjaliści
          </span>
        </p>
        <h2 class="text-3xl lg:text-section-title font-semibold leading-tight text-black mb-6">
          Kto odpowiada na Twoje pytania?
        </h2>
        <p class="text-base lg:text-body-lg leading-relaxed text-brand-text max-w-[560px]">
          Jesteśmy specjalistami w temacie cyberbezpieczeństwa, ale wyjaśniamy wszystko zrozumiałym językiem — bez żargonu technicznego czy prawnego.
        </p>
        <img
          src="/img/tlo-biale-strzalki-w-dol-2.svg"
          alt=""
          aria-hidden="true"
          class="pointer-events-none select-none hidden lg:block absolute -left-24 -bottom-32 w-[600px] max-w-none -z-10"
        />
      </div>

      <div class="bg-brand-navy text-white rounded-card p-8 lg:p-10 flex flex-col gap-6">
        <h3 class="text-xl lg:text-[26px] font-semibold leading-snug">
          Na Twoje pytania odpowiada doświadczony konsultant, który ma wsparcie zespołu ekspertów: prawników specjalizujących się w RODO, specjalistów od cyberbezpieczeństwa oraz architektów systemów IT.
        </h3>
        <p class="text-base lg:text-body-lg leading-relaxed text-white/85">
          Jeśli Twoje zagadnienie wymaga głębokiej wiedzy specjalistycznej — konsultant może wrócić do Ciebie z dodatkowymi informacjami po zasięgnięciu opinii specjalistycznej. Dzięki temu otrzymujesz nie tylko bezpośrednią odpowiedź, ale także pewność, że informacje pochodzą od osób z wieloletnim doświadczeniem w konkretnych dziedzinach bezpieczeństwa IT i zgodności z przepisami.
        </p>
      </div>
    </div>
  </Section>

  <!-- ======== SEKCJA: Jak umówić się na konsultacje (full-bleed gray) ======== -->
  <Section bg="bg-brand-bg">
    <SectionHeading
      tag="Start"
      title="Jak umówić się na konsultacje?"
      lead="Konsultacje dostępne są po wykupieniu Ochrony 360"
      tagColor="blue"
    />

    <StepsGrid steps={kroki} />
  </Section>

  <!-- ======== SEKCJA: Jakiego rezultatu możesz się spodziewać ======== -->
  <Section padding="tight">
    <SectionHeading tag="Efekty" title="Jakiego rezultatu możesz się spodziewać?" tagColor="blue" />

    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 list-none p-0">
      {rezultaty.map((r) => (
        <li class={`relative ${r.cardBg} rounded-card overflow-hidden p-7 lg:p-8 flex flex-col gap-5 min-h-[424px]`}>
          <h3 class="text-xl lg:text-2xl font-semibold leading-snug text-black">
            {r.title}
          </h3>
          <ul class="list-disc ml-5 space-y-1.5 text-body lg:text-base leading-cozy text-brand-text marker:text-brand-text flex-1">
            {r.items.map((i) => <li>{i}</li>)}
          </ul>
          <p class="font-medium uppercase text-xs tracking-wide">
            <span class={`inline-flex items-center gap-2 ${r.tagBg} border border-black/10 px-3 py-1.5 rounded-full text-black`}>
              <img src="/img/mini-sygnet.svg" alt="" aria-hidden="true" class="w-[15px] h-auto" />
              {r.tag}
            </span>
          </p>
        </li>
      ))}
    </ul>
  </Section>

  <!-- ======== SEKCJA: FAQ ======== -->
  <Section padding="tight">
    <SectionHeading tag="FAQ" title="Częste wątpliwości przed konsultacją" tagColor="cream" />

    <div class="max-w-[890px] mx-auto flex flex-col gap-3">
      {faq.map((item, i) => (
        <details
          class="group bg-brand-bg border border-brand-border rounded-card overflow-hidden"
          open={i === 0}
        >
          <summary
            class="flex items-center justify-between gap-4 p-5 lg:px-7 lg:py-5 cursor-pointer select-none list-none"
          >
            <span class="text-base lg:text-card-heading font-semibold leading-snug text-black">
              {item.q}
            </span>
            <span
              class="inline-flex items-center justify-center w-10 h-10 lg:w-12 lg:h-12 rounded-full border border-brand-border shrink-0 transition-transform group-open:rotate-45"
              aria-hidden="true"
            >
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 2v14M2 9h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              </svg>
            </span>
          </summary>
          <div class="px-5 pb-6 lg:px-7 lg:pb-7 text-base leading-cozy text-brand-text">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </Section>

  <CtaReady />
</BaseLayout>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary { list-style: none; }
</style>

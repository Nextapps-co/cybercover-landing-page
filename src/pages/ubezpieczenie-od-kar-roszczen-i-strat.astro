---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Section from '../components/Section.astro'
import SectionHeading from '../components/SectionHeading.astro'
import ArrowButton from '../components/ArrowButton.astro'
import ActionButton from '../components/ActionButton.astro'
import CtaReady from '../components/CtaReady.astro'
import ubezpieczenieHero from '../assets/img/Ubezpieczenie-portal.jpg'

const dlaczego = [
  {
    icon: '/img/ico-koszty-obslugi.svg',
    title: 'Trudno przewidzieć koszty obsługi cyberataku',
    desc: 'Koszty mogą wynosić od kilku tysięcy do milionów złotych. Ciężko zaplanować takie wydatki w budżecie rocznym.',
  },
  {
    icon: '/img/ico-kary.svg',
    title: 'Kary, odszkodowania i roszczenia mogą być bardzo wysokie',
    desc: 'Kary administracyjne, odszkodowania i roszczenia osób trzecich mogą być ogromne. Ich zapłata jest nieunikniona po incydencie.',
  },
  {
    icon: '/img/ico-koszty-specjalistow.svg',
    title: 'Koszty specjalistów mogą przerosnąć Twoje możliwości',
    desc: 'Informatycy śledczy, prawnicy i specjaliści PR kosztują bardzo drogo. W kryzysie ich dostępność jest ograniczona, a ceny jeszcze wyższe.',
  },
]

const pokrywa = [
  {
    title: 'Koszty związane z wymuszeniami',
    example: 'Hakerzy zaszyfrowali system organizacji i żądają okupu — ubezpieczenie może pokryć koszty związane z tym wymuszeniem.',
  },
  {
    title: 'Koszty utraty korzyści majątkowych',
    example: 'Atak sparaliżował sklep internetowy na kilka dni — ubezpieczenie zrekompensuje utracony zysk ze sprzedaży w tym okresie.',
  },
  {
    title: 'Koszty wizerunkowe i komunikacyjne',
    example: 'Po wycieku danych organizacja potrzebuje kampanii PR, aby odbudować zaufanie klientów — ubezpieczenie pokryje koszty agencji PR i działań komunikacyjnych.',
  },
  {
    title: 'Koszty reagowania i naprawy szkód',
    example: 'Organizacja padła ofiarą ataku z wymuszeniem okupu — ubezpieczenie pokryje koszty informatyków śledczych, którzy będą analizować sposób włamania i zakres szkód.',
  },
  {
    title: 'Koszty prawno-administracyjne',
    example: 'Po wycieku danych osobowych klientów organizacja musi wypełnić obowiązek informacyjny wobec UODO — ubezpieczenie pokryje koszty prawników przygotowujących odpowiednie zawiadomienia.',
  },
  {
    title: 'Koszty roszczeń i odpowiedzialności',
    example: 'Klient pozwał organizację o odszkodowanie po wycieku jego danych osobowych — ubezpieczenie pokryje koszty postępowania i ewentualne odszkodowanie.',
  },
  {
    title: 'Koszty odtworzenia danych i systemów',
    example: 'Atak uszkodził dane i oprogramowanie organizacji — ubezpieczenie pokryje koszty odzyskania i odtworzenia danych, ponownej instalacji oprogramowania, a gdy naprawa się nie opłaca, także wymiany systemów na sprawne.',
  },
  {
    title: 'Koszty odpowiedzialności multimedialnej',
    example: 'Treść opublikowana w kanałach cyfrowych organizacji naruszyła cudze prawa autorskie lub dobre imię — ubezpieczenie pokryje odszkodowanie i koszty obrony w związku z takim roszczeniem.',
  },
]

const pomagamy = [
  'Ocenią aktualny stan zabezpieczeń Twojej organizacji',
  'Wskażą konkretne kroki do spełnienia wymagań',
  'Polecą sprawdzone rozwiązania techniczne',
  'a jeśli trzeba, to także pomogą w implementacji niezbędnych zabezpieczeń',
]

const wymagania = [
  {
    title: 'Kopie zapasowe danych',
    desc: 'Posiadasz kopie zapasowe najważniejszych danych i przechowujesz je w innym miejscu niż oryginały — np. w chmurze lub na zewnętrznym dysku.',
  },
  {
    title: 'Aktualizacje oprogramowania',
    desc: 'Regularnie aktualizujesz systemy operacyjne oraz kluczowe oprogramowanie.',
  },
]

const faq = [
  {
    q: 'Dlaczego tradycyjne OC nie wystarczy?',
    a: 'Tradycyjne polisy dla organizacji nie są przystosowane do współczesnych zagrożeń cybernetycznych i pozostawiają znaczące luki w ochronie. To ubezpieczenie zostało stworzone właśnie po to, aby wypełnić te braki. Największe problemy z konwencjonalnymi polisami to brak zabezpieczenia finansowego na wypadek unieruchomienia systemów IT, brak możliwości pokrycia kosztów związanych z atakami i wymuszeniami, niewłączenie wydatków na śledztwa informatyczne oraz brak ochrony przed sankcjami wynikającymi z naruszenia RODO.',
  },
  {
    q: 'Dla jakiej wielkości organizacji to ma sens?',
    a: 'Zagrożenia cybernetyczne nie wybierają swoich ofiar ze względu na rozmiar czy sektor działalności — dotykają zarówno małe przedsiębiorstwa, jak i wielkie korporacje. Decydującym czynnikiem nie jest skala biznesu, lecz stopień narażenia na cyberataki. Nawet niewielka organizacja może stać się atrakcyjnym celem dla cyberprzestępców, jeśli posiada słabe zabezpieczenia lub przetwarza cenne dane.',
  },
  {
    q: 'Kiedy ubezpieczenie i natychmiastowa pomoc 24/7 są aktywne?',
    a: 'Ubezpieczenie oraz natychmiastowa pomoc 24/7 uruchamiają się, gdy spełnisz dwa proste wymagania bezpieczeństwa: kopie zapasowe danych oraz regularne aktualizacje oprogramowania. Jeśli na starcie ich nie spełniasz, usługa CyberCover — ocena bezpieczeństwa, monitoring zagrożeń i konsultacje — działa od razu, a po spełnieniu wymagań aktywują się również ubezpieczenie i pomoc 24/7. Pomagamy je spełnić w ramach konsultacji z ekspertami lub dodatkowego wsparcia.',
  },
  {
    q: 'Jakie są inne ograniczenia ochrony ubezpieczeniowej?',
    a: 'Ubezpieczenie od ryzyk cybernetycznych zawiera określone wyłączenia i ograniczenia ochrony. Polisa nie obejmuje szkód powstałych w wyniku działań wojennych, strajków, terroryzmu i podobnych zdarzeń — z wyłączeniem aktów cyberterroryzmu, które pozostają objęte ochroną. Wyłączone są także szkody wynikające z awarii zewnętrznych sieci (energetycznych, telekomunikacyjnych, w tym internetu), na przykład przerw w dostawie prądu, szkody na osobie i w mieniu materialnym (innym niż dane), a także umyślne działania członków władz organizacji.',
  },
  {
    q: 'Czego nie pokrywa ubezpieczenie?',
    a: 'Ochrona nie obejmuje m.in.: okoliczności, roszczeń i incydentów znanych lub zgłoszonych przed zawarciem umowy oraz zdarzeń sprzed daty wstecznej; strat z błędnych elektronicznych przelewów i transakcji finansowych (środki utracone, sfałszowane lub uszkodzone podczas transferu); kar i grzywien o charakterze cywilnym, karnym oraz karnoskarbowym; a także szkód związanych z kryptowalutami. Koszty obrony są pokrywane do czasu prawomocnego potwierdzenia, że doszło do czynu przestępczego lub umyślnego naruszenia prawa.',
  },
]
---

<BaseLayout
  title="Ubezpieczenie od kar, roszczeń i strat – CyberCover"
  description="Ubezpieczenie pokryje kary urzędowe, odszkodowania, koszty okupu, roszczenia firm i osób, jak również utracone korzyści. Zawarte w cenie usługi."
>
  <Hero
    badge="Ochrona 360"
    title="Ubezpieczenie od kar, roszczeń i strat"
    intro="Ubezpieczenie pokryje kary urzędowe, odszkodowania, koszty okupu, roszczenia firm i osób, jak również utracone korzyści."
    subtitle="Ubezpieczenie zawarte w cenie usługi."
    introSize="xl"
    bg="white"
    image={ubezpieczenieHero}
    imageAlt="Ubezpieczenie od kar, roszczeń i strat — ilustracja"
  >
    <ArrowButton slot="cta" label="Wykup Ochronę 360" class="mt-2" />
  </Hero>

  <!-- ======== SEKCJA: Dlaczego ochrona finansowa jest ważna? ======== -->
  <Section>
    <SectionHeading tag="Ubezpieczenie" title="Dlaczego ochrona finansowa jest ważna?" tagColor="cream" />

    <ul class="grid grid-cols-1 md:grid-cols-3 gap-5 list-none p-0">
      {dlaczego.map((item) => (
        <li
          class="relative bg-white rounded-card overflow-hidden min-h-[270px] p-7 lg:p-8 flex flex-col gap-6"
          style="background-image:url('/img/tlo-box-szersze.svg'); background-repeat:no-repeat; background-position:top right; background-size:cover;"
        >
          <img src={item.icon} alt="" aria-hidden="true" class="w-10 h-12 lg:w-12 lg:h-14 -mt-7 lg:-mt-8" />
          <h3 class="text-[22px] font-semibold leading-snug text-black">
            {item.title}
          </h3>
          <p class="text-base leading-cozy text-brand-text">
            {item.desc}
          </p>
        </li>
      ))}
    </ul>
  </Section>

  <!-- ======== SEKCJA: Co pokrywa ubezpieczenie ======== -->
  <Section padding="tight">
    <SectionHeading tag="Zakres" title="Co pokrywa ubezpieczenie" tagColor="yellow" />

    <ul class="grid grid-cols-1 md:grid-cols-2 gap-5 list-none p-0">
      {pokrywa.map((p) => (
        <li class="bg-brand-bg border border-brand-border rounded-card p-7 lg:p-8 flex flex-col gap-4">
          <h3 class="text-xl lg:text-2xl font-semibold leading-snug text-black">
            {p.title}
          </h3>
          <p class="font-medium uppercase text-xs tracking-wide">
            <span class="inline-flex items-center gap-2 bg-brand-blue-light border border-brand-blue-light px-3 py-1.5 rounded-full text-black">
              <img src="/img/mini-sygnet.svg" alt="" aria-hidden="true" class="w-[15px] h-auto" />
              Przykład
            </span>
          </p>
          <p class="text-base leading-cozy text-brand-text">
            {p.example}
          </p>
        </li>
      ))}
    </ul>
  </Section>

  <!-- ======== SEKCJA: Dokumenty (full-bleed blue) ======== -->
  <Section bg="bg-[#EAF4FB]" class="relative overflow-hidden">
    <!-- Dekoracyjne strzałki w tle (jak w CtaReady) -->
    <svg
      class="pointer-events-none absolute top-1/2 right-0 -translate-y-1/2 h-[155%] w-auto opacity-50 select-none"
      viewBox="0 0 700 519"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
      fill="none"
    >
      <defs>
        <linearGradient id="owu-arrow-grad" x1="0.5" y1="0" x2="0.5" y2="1" gradientUnits="objectBoundingBox">
          <stop offset="0" stop-color="#fff" stop-opacity="0"/>
          <stop offset="1" stop-color="#a7a7a7" stop-opacity="0.35"/>
        </linearGradient>
      </defs>
      <g fill="url(#owu-arrow-grad)">
        <path transform="translate(280 -50) rotate(90 283 340) scale(0.75)" d="M1.449,408.126q4.03,14.84,19.2,29.928l9.93,9.869,211.486,210.1q20.672,20.523,40.849,20.517t40.849-20.517l211.486-210.1,9.93-9.869q15.193-15.1,19.2-29.928a40.582,40.582,0,0,0,1.473-10.649V57.391q0-29.048-14.289-43.2Q537.309.019,508.087,0H57.775Q28.522,0,14.289,14.19.025,28.361,0,57.391V397.478a40.583,40.583,0,0,0,1.473,10.649H1.449Z"/>
        <path transform="translate(480 -50) rotate(90 283 340) scale(0.75)" d="M1.449,408.126q4.03,14.84,19.2,29.928l9.93,9.869,211.486,210.1q20.672,20.523,40.849,20.517t40.849-20.517l211.486-210.1,9.93-9.869q15.193-15.1,19.2-29.928a40.582,40.582,0,0,0,1.473-10.649V57.391q0-29.048-14.289-43.2Q537.309.019,508.087,0H57.775Q28.522,0,14.289,14.19.025,28.361,0,57.391V397.478a40.583,40.583,0,0,0,1.473,10.649H1.449Z"/>
      </g>
    </svg>
    <div
      class="relative grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start"
    >
      <div class="flex flex-col gap-5">
        <h3 class="text-2xl lg:text-card-title font-semibold leading-tight text-black max-w-[500px]">
          Dokładne informacje znajdziesz w tych dokumentach
        </h3>
        <p class="font-medium uppercase text-xs tracking-wide">
          <span class="inline-flex items-center gap-2 border border-brand-border px-3 py-1.5 rounded-full text-black">
            <img src="/img/mini-sygnet.svg" alt="" aria-hidden="true" class="w-[15px] h-auto" />
            dokumenty
          </span>
        </p>
      </div>
      <div class="flex flex-col gap-6 max-w-[500px]">
        <p class="text-base lg:text-body-lg leading-relaxed text-brand-text">
          Jeśli zależy Ci na pełnym zrozumieniu wszystkich aspektów ubezpieczenia, zachęcamy do zapoznania się z tymi materiałami.
        </p>
        <div class="flex">
          <a
            href="/docs/OWU_Cyber_0104_2026.pdf"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 bg-white border border-brand-border hover:bg-brand-bg text-black font-semibold text-base px-6 py-3 rounded-full transition-colors"
          >
            Ogólne Warunki Ubezpieczenia
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </Section>

  <!-- ======== SEKCJA: Wymagania ======== -->
  <Section padding="tight" class="relative">
    <img
      src="/img/tlo-biale-kulki.svg"
      alt=""
      aria-hidden="true"
      class="pointer-events-none select-none hidden lg:block absolute left-[220px] top-16 w-[480px] max-w-none -z-10"
    />
    <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start mb-10 lg:mb-14">
      <div>
        <p class="font-medium uppercase text-sm tracking-wide mb-4">
          <span class="inline-flex items-center gap-2 bg-brand-tag-yellow border border-brand-tag-yellow px-4 py-1.5 rounded-full">
            <img src="/img/mini-sygnet.svg" alt="" aria-hidden="true" class="w-[19px] h-auto" />
            wymagania
          </span>
        </p>
        <h2 class="text-3xl lg:text-section-title font-semibold leading-tight text-black">
          Jakie standardy należy spełniać, aby ubezpieczenie zadziałało?
        </h2>
      </div>
      <div class="flex flex-col gap-6">
        <p class="text-base lg:text-body-lg leading-relaxed text-brand-text">
          Wymagania są proste — to dwie standardowe praktyki bezpieczeństwa, które warto stosować w każdej organizacji. Bez audytów technicznych ani skomplikowanej dokumentacji.
        </p>
        {wymagania.map((w) => (
          <div class="flex flex-col gap-2">
            <h3 class="text-xl lg:text-2xl font-semibold leading-snug text-black">
              {w.title}
            </h3>
            <p class="text-base leading-cozy text-brand-text">
              {w.desc}
            </p>
          </div>
        ))}
        <p class="text-base leading-cozy text-brand-text">
          Jeśli jeszcze nie spełniasz tych wymagań — nic straconego. Usługa CyberCover (ocena bezpieczeństwa, monitoring i konsultacje) działa od razu, a ubezpieczenie oraz natychmiastowa pomoc 24/7 uruchamiają się po ich spełnieniu. <strong>Pomożemy Ci je spełnić</strong> — w ramach konsultacji z ekspertami lub dodatkowego wsparcia.
        </p>
      </div>
    </div>

    <div class="relative bg-brand-navy text-white rounded-card p-8 lg:p-10 grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <div class="flex flex-col gap-6 lg:justify-between">
        <h3 class="text-2xl lg:text-[28px] font-semibold leading-tight">
          Pomagamy w spełnieniu tych wymagań
        </h3>
        <div>
          <ActionButton variant="yellow" label="Wykup ochronę on-line" href="/cennik" />
        </div>
      </div>
      <div class="flex flex-col gap-4">
        <h4 class="text-lg lg:text-card-heading font-medium leading-snug">
          Po wykupieniu naszej oferty otrzymujesz konsultacje z ekspertami cyberbezpieczeństwa, którzy:
        </h4>
        <ul class="list-disc ml-5 space-y-2 text-base lg:text-body-lg leading-relaxed text-white/90 marker:text-white">
          {pomagamy.map((p) => <li>{p}</li>)}
        </ul>
      </div>
    </div>
  </Section>

  <!-- ======== SEKCJA: FAQ ======== -->
  <Section padding="tight">
    <SectionHeading tag="FAQ" title="Najczęściej zadawane pytania" tagColor="peach" />

    <div class="max-w-[890px] mx-auto flex flex-col gap-3">
      {faq.map((item, i) => (
        <details
          class="group bg-brand-bg border border-brand-border rounded-card overflow-hidden"
          open={i === 0}
        >
          <summary
            class="flex items-center justify-between gap-4 p-5 lg:px-7 lg:py-5 cursor-pointer select-none list-none"
          >
            <span class="text-base lg:text-card-heading font-semibold leading-snug text-black">
              {item.q}
            </span>
            <span
              class="inline-flex items-center justify-center w-10 h-10 lg:w-12 lg:h-12 rounded-full border border-brand-border shrink-0 transition-transform group-open:rotate-45"
              aria-hidden="true"
            >
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 2v14M2 9h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              </svg>
            </span>
          </summary>
          <div class="px-5 pb-6 lg:px-7 lg:pb-7 text-base leading-cozy text-brand-text">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </Section>

  <CtaReady />
</BaseLayout>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary { list-style: none; }
</style>

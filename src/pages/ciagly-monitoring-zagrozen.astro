---
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Section from '../components/Section.astro'
import SectionHeading from '../components/SectionHeading.astro'
import StepsGrid from '../components/StepsGrid.astro'
import ArrowButton from '../components/ArrowButton.astro'
import CtaReady from '../components/CtaReady.astro'
import monitoringHero from '../assets/img/Monitoring-zagrozen-portal.jpg'
import sectionImg from '../assets/img/Image.jpg'

const dlaczego = [
  {
    icon: '/img/ico-szybkosc.svg',
    title: 'Hakerzy działają szybko',
    desc: 'udany cyberatak może kosztować organizację równowartość kilkuletnich zysków, uwzględniając straty finansowe, kary prawne, koszty odbudowy systemów i utratę klientów',
  },
  {
    icon: '/img/ico-wyciek.svg',
    title: 'Jeden wyciek = wiele zagrożeń',
    desc: 'jeśli ktoś używa tego samego hasła w kilku miejscach, hackerzy mogą przejąć wszystkie konta naraz i dotrzeć do wrażliwych danych Twojej organizacji oraz Twoich klientów.',
  },
  {
    icon: '/img/ico-koszty.svg',
    title: 'Koszty ataków są ogromne',
    desc: 'udany cyberatak może kosztować organizację równowartość kilkuletnich zysków, uwzględniając straty finansowe, kary prawne, koszty odbudowy systemów i utratę klientów',
  },
]

const monitoringSections = [
  {
    title: 'Monitoring wycieków danych',
    desc: 'Podajesz adresy e-mail (właścicieli i pracowników), a my cyklicznie sprawdzamy, czy nie pojawiły się w wyciekach danych z zewnętrznych serwisów.',
    items: [],
    subTitle: 'Co pokazujemy',
    subItems: [
      'w którym serwisie doszło do wycieku i kiedy',
      'skalę wycieku — ile kont zostało ujawnionych',
      'co wyciekło — np. hasła, adresy e-mail, imiona i nazwiska, daty urodzenia',
      'czy to nowy wyciek, czy znaleziony już we wcześniejszym skanie',
    ],
    image: sectionImg,
    imageAlt: 'Monitoring wycieków danych — placeholder',
    imagePosition: 'right' as const,
  },
  {
    title: 'Monitoring strony',
    desc: 'Podajesz adres swojej strony www, a my cyklicznie sprawdzamy jej stan i bezpieczeństwo.',
    items: [],
    subTitle: 'Co sprawdzamy',
    subItems: [
      'Dostępność — czy serwer działa nieprzerwanie; gdy strona nie działa, tracisz klientów',
      'Szybkość ładowania — jak szybko strona uruchamia się u klienta',
      'Jakość strony — wydajność, dostępność, widoczność w wyszukiwarkach (SEO) i standardy, osobno na komputerze i telefonie',
      'Ważność domeny — kiedy wygasa; wygaśnięcie zablokuje stronę i pocztę e-mail',
      'Certyfikat bezpieczeństwa (SSL) — po jego wygaśnięciu przeglądarki oznaczą stronę jako niebezpieczną',
      'Szczegółowy raport — gotowy do przekazania osobie odpowiedzialnej za IT',
    ],
    image: sectionImg,
    imageAlt: 'Monitoring strony — placeholder',
    imagePosition: 'left' as const,
  },
  {
    title: 'Co robimy, gdy wykryjemy zagrożenie?',
    desc: '',
    items: [],
    subTitle: 'Otrzymujesz natychmiastowy alert i plan działania',
    subItems: [
      'Dostaniesz powiadomienie z opisem zagrożenia.',
      'Otrzymasz konkretne kroki do natychmiastowego wykonania.',
      'Możesz także umówić się z konsultantem, aby wyjaśnić detale.',
    ],
    image: sectionImg,
    imageAlt: 'Reakcja na zagrożenie — placeholder',
    imagePosition: 'right' as const,
  },
]

const korzysci = [
  {
    bg: '/img/tlo-zolte-kula-1.svg',
    title: 'Wczesne ostrzeżenie',
    desc: 'dowiadujesz się o zagrożeniu zanim hakerzy zaatakują',
    tag: 'Prewencja',
    tagBg: 'bg-white',
  },
  {
    bg: '/img/tlo-zolte-kula-2.svg',
    title: 'Bezpieczeństwo właścicieli i pracowników',
    desc: 'chronisz dane osobowe i służbowe swojego zespołu',
    tag: 'Bezpieczeństwo',
    tagBg: 'bg-[#FFF5E0]',
  },
  {
    bg: '/img/tlo-zolte-strzalka-w-dol.svg',
    title: 'Unikanie kar prawnych',
    desc: 'proaktywne działanie chroni przed karami za wycieki danych',
    tag: 'Zgodność z RODO',
    tagBg: 'bg-brand-tag-blue',
  },
]

const kroki = [
  { n: '01', text: 'Zaloguj się do Portalu Klienta' },
  { n: '02', text: 'Wybierz dane, które chcesz monitorować' },
  {
    n: '03',
    text: 'Dostaniesz cykliczne raporty z monitoringu wraz z informacją co zrobić w razie problemów',
    note: 'Jeśli będziesz mieć pytania zawsze możesz umówić się na konsultacje.',
    image: '/img/krok-3.png',
  },
]
---

<BaseLayout
  title="Ciągły monitoring zagrożeń – CyberCover"
  description="Sprawdzamy, czy Twoje dane nie wyciekły w zewnętrznych serwisach, oraz monitorujemy stan i bezpieczeństwo Twojej strony www."
>
  <Hero
    badge="Ochrona 360"
    title="Ciągły monitoring zagrożeń"
    intro="Sprawdzamy, czy Twoje dane nie wyciekły, oraz monitorujemy stan i bezpieczeństwo Twojej strony www."
    subtitle="Gdy wykryjemy problem, od razu informujemy co trzeba zrobić."
    introSize="xl"
    bg="white"
    image={monitoringHero}
    imageAlt="Ciągły monitoring zagrożeń — ilustracja"
  >
    <ArrowButton slot="cta" label="Włącz monitoring zagrożeń" class="mt-2" />
  </Hero>

  <!-- ======== SEKCJA: Dlaczego skanowanie zagrożeń jest ważne? ======== -->
  <Section>
    <SectionHeading tag="Monitoring" title="Dlaczego skanowanie zagrożeń jest ważne?" tagColor="blue-light" />

    <ul class="grid grid-cols-1 md:grid-cols-3 gap-5 list-none p-0">
      {dlaczego.map((item) => (
        <li
          class="relative bg-white rounded-card overflow-hidden min-h-[270px] p-7 lg:p-8 flex flex-col gap-7"
          style="background-image:url('/img/tlo-box-szersze.svg'); background-repeat:no-repeat; background-position:top right; background-size:cover;"
        >
          <img src={item.icon} alt="" aria-hidden="true" class="w-10 h-12 lg:w-12 lg:h-14 -mt-7 lg:-mt-8" />
          <h3 class="text-[22px] font-semibold leading-snug text-black">
            {item.title}
          </h3>
          <p class="text-base leading-cozy text-brand-text">
            {item.desc}
          </p>
        </li>
      ))}
    </ul>
  </Section>

  <!-- ======== SEKCJA: Jakie dane monitorujemy ======== -->
  <Section padding="tight">
    <SectionHeading tag="Zakres" title="Co monitorujemy?" tagColor="yellow" margin="mb-12 lg:mb-16" />

    <div class="flex flex-col gap-12 lg:gap-16">
      {monitoringSections.map((s) => (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <div class={`flex flex-col gap-5 ${s.imagePosition === 'left' ? 'lg:order-2' : ''}`}>
            <h3 class="text-2xl lg:text-card-title font-semibold leading-tight text-black">
              {s.title}
            </h3>
            {s.desc && (
              <p class="text-base lg:text-body-lg leading-relaxed text-brand-text">
                {s.desc}
              </p>
            )}
            {s.items.length > 0 && (
              <ul class="list-disc ml-5 space-y-2 text-base lg:text-body-lg leading-cozy text-brand-text marker:text-brand-text">
                {s.items.map((i) => <li>{i}</li>)}
              </ul>
            )}
            {s.subTitle && (
              <h4 class="text-lg lg:text-card-heading font-medium leading-snug text-black mt-2">
                {s.subTitle}
              </h4>
            )}
            {s.subItems.length > 0 && (
              <ul class="list-disc ml-5 space-y-2 text-base lg:text-body-lg leading-cozy text-brand-text marker:text-brand-text">
                {s.subItems.map((i) => <li>{i}</li>)}
              </ul>
            )}
          </div>
          <div class={`relative rounded-card overflow-hidden min-h-[300px] lg:min-h-[366px] ${s.imagePosition === 'left' ? 'lg:order-1' : ''}`}>
            <Image
              src={s.image}
              alt={s.imageAlt}
              width={900}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- ======== SEKCJA: Jakie są korzyści z monitoringu? ======== -->
  <Section padding="tight">
    <SectionHeading tag="Korzyści" title="Jakie są korzyści z monitoringu?" tagColor="blue" />

    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 list-none p-0">
      {korzysci.map((k) => (
        <li
          class="relative bg-brand-tag-yellow rounded-card overflow-hidden p-7 lg:p-8 flex flex-col min-h-[424px]"
          style={`background-image:url('${k.bg}'); background-repeat:no-repeat; background-position:center; background-size:cover;`}
        >
          <div class="relative flex-1 flex flex-col justify-center gap-4">
            <h3 class="text-lg lg:text-xl font-semibold leading-snug text-black">
              {k.title}
            </h3>
            <p class="text-sm leading-relaxed text-brand-text">
              {k.desc}
            </p>
          </div>
          <p class="relative font-medium uppercase text-xs tracking-wide">
            <span class={`inline-flex items-center gap-2 ${k.tagBg} border border-black/10 px-3 py-1.5 rounded-full text-black`}>
              <img src="/img/mini-sygnet.svg" alt="" aria-hidden="true" class="w-[15px] h-auto" />
              {k.tag}
            </span>
          </p>
        </li>
      ))}
    </ul>
  </Section>

  <!-- ======== SEKCJA: Jak włączyć monitoring (full-bleed blue) ======== -->
  <Section bg="bg-brand-blue-light">
    <SectionHeading
      tag="Start"
      title="Jak włączyć monitoring?"
      lead="Monitoring jest dostępny po wykupieniu Ochrony 360"
      tagColor="blue"
    />

    <StepsGrid steps={kroki} />
  </Section>

  <CtaReady />
</BaseLayout>

---
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import SectionTag from '../components/SectionTag.astro'
import ArrowButton from '../components/ArrowButton.astro'
import Ochrona360 from '../components/Ochrona360.astro'

import heroImg from '../assets/img/ochrona-twojej-firmy-cena.jpg'
import ocenaImg from '../assets/img/Ocena.jpg'
import konsultacjeImg from '../assets/img/Konsultacje-portal.jpg'
import monitoringImg from '../assets/img/Monitoring-zagrozen-portal.jpg'
import pomocImg from '../assets/img/Natychmiastowa-pomoc-portal.jpg'
import ubezpieczenieImg from '../assets/img/Ubezpieczenie-portal.jpg'
import nis2Img from '../assets/img/wymagania-nis2x2.jpg'

const threats = [
  { icon: '/img/ico-kradziez-danych.svg', title: 'Kradzież danych osobowych przez pracownika', desc: 'Nieuczciwy członek zespołu wykradł 700 rekordów z danymi klientów. Incydent wymagał natychmiastowego powiadomienia UODO.' },
  { icon: '/img/ico-podszywanie-sie-pod-prezesa-firmy.svg', title: 'Podszywanie się pod prezesa organizacji', desc: 'W pilnej wiadomości „prezes" prosił o pilny przelew dla ważnego partnera. Księgowa, nie weryfikując tożsamości nadawcy, przelała środki na wskazane konto przestępców.' },
  { icon: '/img/ico-wyludzenie-danych-logowania.svg', title: 'Wyłudzenie danych logowania', desc: 'Pracownik otrzymał wiarygodną wiadomość od działu IT z prośbą o weryfikację konta na nowej platformie. Przestępcy uzyskali dostęp do służbowej skrzynki pocztowej z poufnymi informacjami o klientach.' },
  { icon: '/img/ico-paraliz-dzialania.svg', title: 'Paraliż działania z żądaniem okupu', desc: 'Hakerzy zaszyfrowali dane księgowe biura rachunkowego w szczycie okresu rozliczeń. Dostęp do dokumentów klientów został zablokowany do czasu zapłaty okupu.' },
]

const challenges = [
  'Brak wiedzy jak w pełni zabezpieczyć się przed wyciekiem danych i atakami na organizację.',
  'Odpowiedzialność osobista za kary urzędowe, roszczenia, okup i pozwy sądowe',
  'Jeśli coś się stanie, to nie wiadomo do kogo się zgłosić po wsparcie.',
]

const services = [
  { id: 'ocena-bezpieczenstwa', href: '/ocena-bezpieczenstwa-i-zalecenia', icon: '/img/ico-ocena-bezpieczenstwa.svg', title: 'Ocena bezpieczeństwa i zalecenia', desc: 'Przeprowadzamy cykliczny przegląd bezpieczeństwa, dajemy ocenę i rekomendacje, dostajesz gotowy plan działania dla twojego zespołu i zawsze możesz się z nami skonsultować jeśli potrzebujesz dodatkowego wsparcia.', img: ocenaImg, imgAlt: 'Ocena bezpieczeństwa' },
  { id: 'konsultacje', href: '/konsultacje-z-ekspertami', icon: '/img/ico-konsultacje-z-ekspertami.svg', title: 'Konsultacje z ekspertami', desc: 'Dajemy dostęp do doświadczonych specjalistów od cyberbezpieczeństwa i RODO, odpowiadamy na pytania i wątpliwości dotyczące ochrony danych w organizacji.', img: konsultacjeImg, imgAlt: 'Konsultacje' },
  { id: 'monitoring', href: '/ciagly-monitoring-zagrozen', icon: '/img/ico-ciagly-monitoring-zagrozen.svg', title: 'Ciągły monitoring zagrożeń', desc: 'Sprawdzamy, czy dane Twojej organizacji nie wyciekły w zewnętrznych serwisach, oraz monitorujemy stan i bezpieczeństwo Twojej strony www. Gdy wykryjemy problem, od razu informujemy co trzeba zrobić.', img: monitoringImg, imgAlt: 'Monitoring zagrożeń' },
  { id: 'pomoc-247', href: '/natychmiastowa-pomoc-24-7', icon: '/img/ico-natychmiastowa-pomoc-24-7.svg', title: 'Natychmiastowa pomoc 24/7', desc: 'W razie problemów masz przycisk alarmowy – gdzie zapewniamy ekspertów cyberbezpieczeństwa, mediatorów ds. zarządzania incydentami, radców prawnych oraz specjalistów ds. komunikacji kryzysowej i zarządzania reputacją online.', img: pomocImg, imgAlt: 'Natychmiastowa pomoc' },
  { id: 'ubezpieczenie', href: '/ubezpieczenie-od-kar-roszczen-i-strat', icon: '/img/ico-ubezpieczenie-od-kar-roszczen-i-strat.svg', title: 'Ubezpieczenie od kar, roszczeń i strat', desc: 'Ubezpieczenie pokryje kary finansowe nałożone przez urzędy, odszkodowania w wyniku naruszenia danych, jak również utracone korzyści z powodu paraliżu działania.', img: ubezpieczenieImg, imgAlt: 'Ubezpieczenie' },
]

const steps = [
  { num: '01', title: 'Wypełniasz formularz i wykupujesz usługę', bg: 'bg-brand-blue-light' },
  { num: '02', title: 'Aktywujesz portal i dodajesz osoby z Twojej organizacji', bg: 'bg-[#FDFEDF]' },
  { num: '03', title: 'Wszystko gotowe, możesz czuć się bezpiecznie. A w razie problemów dzwonisz do nas.', bg: 'bg-[#FEF5E0]' },
]

---

<BaseLayout
  title="Cyber Cover – Ochrona organizacji przed cyberatakami i wyciekami danych"
  description="CyberCover dostarcza zalecenia, monitoring zagrożeń i pomoc ekspertów. Ubezpieczenie pokrywa kary RODO, roszczenia i straty."
>
  <!-- ======== HERO ======== -->
  <Hero
    badge="Jedna usługa, pełna ochrona"
    title="Ochrona Twojej organizacji przed wyciekami danych i atakami hackerskimi."
    intro="CyberCover dostarcza zalecenia, monitoring zagrożeń i pomoc ekspertów, a ubezpieczenie pokrywa kary RODO, roszczenia i straty."
    image={heroImg}
    imageAlt="Cyber Cover baner grafika główna"
    introSize="xl"
  >
    <a slot="cta" href="#rozwiazanie" class="inline-flex items-center gap-3 bg-brand-yellow hover:bg-brand-yellow-hover text-black font-semibold text-lg px-8 py-3.5 rounded-full transition-colors">
      Czytaj więcej
      <img src="/img/ico-black-arrow.svg" alt="" class="w-10 h-10" />
    </a>
  </Hero>

  <!-- ======== CYBERZAGROŻENIA ======== -->
  <section class="py-16 lg:py-24">
    <div class="max-w-container mx-auto px-6">
      <SectionTag label="Cyberzagrożenia" />
      <h2 id="cyberzagrozenia" class="text-center text-2xl lg:text-section-title font-semibold leading-tight text-black mt-4 mb-10 lg:mb-16">
        Czego doświadczają organizacje
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5">
        {threats.map(t => (
          <div class="border border-brand-border rounded-card p-8 pb-6">
            <img src={t.icon} alt={t.title} width="50" height="51" class="mb-6" loading="lazy" />
            <h3 class="text-xl font-semibold text-black mb-3">{t.title}</h3>
            <p class="text-body-lg leading-relaxed">{t.desc}</p>
          </div>
        ))}
      </div>
      <div class="flex justify-center mt-10 lg:mt-14">
        <ArrowButton href="/zagrozenia-i-mity" label="Więcej o zagrożeniach" />
      </div>
    </div>
  </section>

  <!-- ======== WYZWANIA ======== -->
  <section class="bg-brand-blue-light py-16 lg:py-24">
    <div class="max-w-container mx-auto px-6">
      <SectionTag label="Wyzwania" />
      <h2 id="wyzwania" class="text-center text-2xl lg:text-section-title font-semibold leading-tight text-black mt-4 mb-10 lg:mb-16">
        Z czym mierzą się zarządzający?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {challenges.map(c => (
          <div class="border border-brand-border rounded-card p-8 min-h-[270px] flex flex-col justify-start bg-[url('/img/tlo-box-szersze.svg')] bg-no-repeat bg-right-top bg-[length:60%_auto]">
            <img src="/img/ico-piorun.svg" alt="" width="49" height="59" class="mb-8" loading="lazy" />
            <h3 class="text-[22px] font-semibold text-black leading-snug max-w-[87%]">{c}</h3>
          </div>
        ))}
      </div>
      <div class="flex justify-center mt-10 lg:mt-14">
        <ArrowButton href="/komu-pomagamy" label="Zobacz komu pomagamy" />
      </div>
    </div>
  </section>

  <!-- ======== NIS2 ======== -->
  <section class="bg-black text-white py-16 lg:py-24">
    <div class="max-w-container mx-auto px-6">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="lg:w-1/2">
          <Image src={nis2Img} alt="Wymagania NIS2" width={627} class="w-full rounded-xl" loading="lazy" />
        </div>
        <div class="lg:w-1/2">
          <p class="font-medium uppercase text-sm tracking-wide mb-4">
            <span class="inline-flex items-center gap-1.5 bg-brand-tag-yellow border border-brand-tag-yellow px-4 py-1 rounded-full text-black">
              <img src="/img/mini-sygnet.svg" alt="" width="19" height="20" class="w-[19px]" />
              Dyrektywa
            </span>
          </p>
          <h2 class="text-2xl lg:text-section-title font-semibold leading-tight mb-6">Wymagania NIS2</h2>
          <p class="text-xl lg:text-2xl font-medium leading-snug text-white/80 mb-6">
            Organizacje z branż IT, zdrowie, transport, administracja publiczna, bankowość, energetyka muszą spełniać surowe wymogi cyberbezpieczeństwa.
          </p>
          <ul class="space-y-2 text-lg text-white/80">
            <li class="flex items-start gap-2.5"><span class="flex h-7 shrink-0 items-center"><span class="h-1.5 w-1.5 rounded-full bg-brand-yellow"></span></span>zarządzanie ryzykiem cybernetycznym</li>
            <li class="flex items-start gap-2.5"><span class="flex h-7 shrink-0 items-center"><span class="h-1.5 w-1.5 rounded-full bg-brand-yellow"></span></span>zgłaszanie incydentów 24-72h</li>
            <li class="flex items-start gap-2.5"><span class="flex h-7 shrink-0 items-center"><span class="h-1.5 w-1.5 rounded-full bg-brand-yellow"></span></span>Kontrola bezpieczeństwa dostawców</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== OCHRONA 360 DIAGRAM ======== -->
  <section id="usluga" class="bg-brand-bg overflow-hidden">
    <div class="pt-16 lg:pt-24 max-w-container mx-auto px-6">
      <SectionTag label="Usługa" variant="blue" />
      <h2 class="text-center text-2xl lg:text-section-title font-semibold leading-tight text-black mt-4 mb-4">
        CyberCover – Ochrona 360
      </h2>
    </div>
    <Ochrona360 />
  </section>

  <!-- ======== ROZWIĄZANIE - SZCZEGÓŁY USŁUG ======== -->
  <section class="py-16 lg:py-24">
    <div class="max-w-container mx-auto px-6">
      <SectionTag label="Rozwiązanie" />
      <h2 id="rozwiazanie" class="text-center text-2xl lg:text-section-title font-semibold leading-tight text-black mt-4 mb-10 lg:mb-16">
        Co zawiera usługa CyberCover?
      </h2>
      <div class="space-y-16">
        {services.map((s, i) => (
          <div class:list={["flex flex-col gap-8 lg:gap-16 items-start", i % 2 === 0 ? "lg:flex-row" : "lg:flex-row-reverse"]}>
            <div class="lg:w-1/2">
              <img src={s.icon} alt="" width="49" height="59" class="mb-4" loading="lazy" />
              <h3 id={s.id} class="text-2xl lg:text-[32px] font-semibold text-black leading-snug mb-4">{s.title}</h3>
              <p class="text-body-lg leading-relaxed mb-6">{s.desc}</p>
              <a href={s.href} class="inline-flex items-center gap-2 text-black font-semibold text-body-lg hover:text-brand-navy transition-colors">
                Czytaj więcej
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>
            <div class="lg:w-1/2">
              <Image src={s.img} alt={s.imgAlt} class="w-full rounded-card" loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======== JAK URUCHOMIĆ ======== -->
  <section class="bg-brand-navy py-16 lg:py-24">
    <div class="max-w-[1350px] mx-auto px-6">
      <p class="text-center font-medium mb-4">
        <span class="inline-flex items-center gap-1.5 bg-brand-tag-yellow border border-brand-tag-yellow px-4 py-1 rounded-full text-black text-sm uppercase tracking-wide">
          <img src="/img/mini-sygnet.svg" alt="" width="19" height="20" class="w-[19px]" />
          Start
        </span>
      </p>
      <h2 class="text-center text-2xl lg:text-section-title font-semibold leading-tight text-white mt-4 mb-10 lg:mb-16">
        Jak uruchomić ochronę Cyber Cover?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {steps.map(step => (
          <div class:list={["rounded-card overflow-hidden", step.bg]}>
            <div class="p-8">
              <div class="flex items-start justify-between mb-6">
                <p class="text-2xl font-medium">KROK</p>
                <p class="text-[58px] font-medium leading-none">{step.num}</p>
              </div>
              <h3 class="text-xl lg:text-2xl font-semibold text-black leading-snug max-w-[85%]">{step.title}</h3>
              <img src="/img/ico-big-arrow.svg" alt="" width="62" height="62" class="mt-8" loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
